{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"ignoreDeprecations": "6.0",
		"jsx": "react-jsx",
		"lib": ["DOM", "DOM.Iterable", "ES2020"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2020"
	},
	"include": ["src"]
}
